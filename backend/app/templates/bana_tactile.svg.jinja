<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 {{ width }} {{ height }}">
  <!-- BANA standard: High contrast, thick lines -->
  <style>
    .room { fill: none; stroke: black; stroke-width: 5px; }
    .door { fill: white; stroke: black; stroke-width: 2px; }
    .label { font-family: Arial, sans-serif; fill: black; font-weight: bold; }
    .low-confidence { stroke-dasharray: 10, 10; stroke: #333; }
  </style>
  <rect width="100%" height="100%" fill="white" />

  <!-- Define clip paths for each room -->
  <defs>
  {% for room in nodes %}
    {% if room.width and room.height %}
    <clipPath id="clip-{{ room.id }}">
      <rect x="{{ room.x + 2 }}" y="{{ room.y + 2 }}"
            width="{{ room.width - 4 }}" height="{{ room.height - 4 }}" />
    </clipPath>
    {% endif %}
  {% endfor %}
  </defs>

  {% for room in nodes %}
    {% if room.width and room.height %}
    <!-- Room outline -->
    <rect
       x="{{ room.x }}"
       y="{{ room.y }}"
       width="{{ room.width }}"
       height="{{ room.height }}"
       class="room {{ 'low-confidence' if room.confidence < 0.8 else '' }}" />

    <!-- Label clipped to room boundary -->
    {% set chars = room.label | length %}
    {% set max_font = [room.width / (chars * 0.55), room.height * 0.35] | min %}
    {% set fsize = [max_font, 22] | min %}
    {% set fsize = [fsize, 7] | max %}

    <text
       x="{{ room.x + room.width / 2 }}"
       y="{{ room.y + room.height / 2 }}"
       class="label"
       text-anchor="middle"
       dominant-baseline="middle"
       font-size="{{ fsize | int }}px"
       clip-path="url(#clip-{{ room.id }})">
      {{ room.label }}
    </text>
    {% endif %}
  {% endfor %}
</svg>
